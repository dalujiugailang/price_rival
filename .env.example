# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DAILY_PRICE_LOOKUP_URL:
# Public daily price API endpoint.
DAILY_PRICE_LOOKUP_URL="https://daily-price.gtmdudu.xyz/api/lookup"

# DAILY_PRICE_TOKEN: Server-side only. Do not expose this value to frontend code.
DAILY_PRICE_TOKEN="MY_DAILY_PRICE_TOKEN"

# APP_PORT: Host port used by docker compose.
APP_PORT=3000

# SQLite database file. Docker uses /app/data/price-rival.sqlite.
DATABASE_PATH="data/price-rival.sqlite"

# Feishu custom app OAuth. Keep APP_SECRET on the server only.
FEISHU_APP_ID="cli_xxx"
FEISHU_APP_SECRET="replace_me"
FEISHU_REDIRECT_URI="http://localhost:3000/api/auth/feishu/callback"

# Comma-separated allowlists. Department IDs should use open_department_id (od-xxx).
FEISHU_ALLOWED_DEPARTMENT_IDS="od-xxx"
FEISHU_ALLOWED_OPEN_IDS=""
FEISHU_ALLOWED_TENANT_KEYS=""

# Local development only. Production ignores this bypass.
AUTH_DEV_BYPASS=false
